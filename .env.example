# CityBrain local MVP configuration

# Admin key for protected admin pages and APIs.
# Change this before any real pilot or shared demo.
CITYBRAIN_ADMIN_KEY=change-this-admin-key

# YOLO vision module endpoint.
# Local default:
VISION_MODULE_URL=http://127.0.0.1:8081/api/congestion/latest

# Default operating window for automatic vision logging.
CITYBRAIN_OPERATING_START=11:30
CITYBRAIN_OPERATING_END=13:30
